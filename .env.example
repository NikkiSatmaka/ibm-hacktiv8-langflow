# Resource limits
LANGFLOW_CPUS_LIMIT=1.0
LANGFLOW_MEM_LIMIT=2g
LANGFLOW_CPUS_RESERVATION=0.25
LANGFLOW_MEM_RESERVATION=256m

# Service identity
LANGFLOW_IMAGE=docker.io/langflowai/langflow:latest

# Langflow Config
LANGFLOW_CONFIG_DIR=/app/langflow
LANGFLOW_AUTO_LOGIN=false
LANGFLOW_SUPERUSER=<your-username>
LANGFLOW_SUPERUSER_PASSWORD=<your-password>
DO_NOT_TRACK=true
